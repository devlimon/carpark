# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carpark?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# SMTP (for monthly statement emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Car Storage <your-email@gmail.com>"

# Cron security — must match the x-cron-secret header sent by Vercel Cron
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-with-another-long-random-string

# Public base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Display name used in emails and PDF reports
CARPARK_NAME=Kerikeri Car Storage
